{
	"sql": "SELECT\nsiswa_baru.nsm,\nsiswa_baru.`jumlah siswa baru`,\n`user`.fullname\nFROM siswa_baru\nRIGHT OUTER JOIN `user` ON `user`.username = siswa_baru.nsm\nWHERE (siswa_baru.`jumlah siswa baru` IS NULL) AND (`user`.fullname not like \"R%%\") AND (`user`.username <> 'admin')",
