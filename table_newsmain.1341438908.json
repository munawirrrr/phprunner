		{
			"eventId": "EVENT_BEFORESHOW_VIEW",
			"pageType": "view",
			"code": "$_SESSION[\"EventsName\"]=$values[\"Title\"];\n$_SESSION[\"Body\"]=\"You have been notified about \\\"\" . $_SESSION[\"EventsName\"] . \"\\\" on \" . format_longdate(db2time(now())) . \"\\n\\n\\n\";\n$_SESSION[\"Body\"].=\"To see more details about this news follow the link below:\" . \"\\n\";\n$keys = $pageObject->keys;\n$_SESSION[\"Body\"].=projectUrl().GetTableLink(\"clmain\",\"view\",\"editid1=\".$keys[\"id\"]) . \"\\n\\n\";\n$_SESSION[\"Body\"].=\"Thanks\";\n\n$stylename = \"newsmain view\";\nif (Security::isLoggedIn())\n\t$stylename.=\" LoggedIn\";\n$xt->assign(\"stylename\",$stylename);\n\n\n\n$xt->assign( \"breadcrumbs\", true );\n$xt->assign( \"breadcrumb\", true );\n$xt->assign(\"crumb_home_link\",GetTableLink(\"newsmain\",\"list\"));\n$breadcrumb = array();\n$breadcrumb[] = array(\"crumb_attrs\" => \"href='\".GetTableLink(\"newsmain\",\"list\").\"?f=(Category~equals~\".rawurlencode($values[\"Category\"]).\")'\", \"crumb_title_link\" => true,\"crumb_title\" => $values[\"Category\"]);\n$breadcrumb[] = array(\"crumb_attrs\" => \"\", \"crumb_title_span\" => true,\"crumb_title\" => $values[\"Title\"]);\n$xt->assign_loopsection(\"crumb\", $breadcrumb);\n\n\n$xt->assign(\"pagetitle\",$values[\"Title\"]);"
		},
